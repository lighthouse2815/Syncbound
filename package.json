{
  "name": "syncbound",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "concurrently -n GAME,SERVER -c cyan,yellow \"vite --host 0.0.0.0\" \"node --watch server/index.js\"",
    "build": "tsc -b && vite build",
    "start": "node server/index.js",
    "test": "node --test server/*.test.js"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
